# Taiwan Stock Reports environment template
# Copy values into PowerShell environment variables or GitHub Actions secrets.
# Do not put real tokens into this file.

# Optional but recommended for higher FinMind quota.
FINMIND_TOKEN=

# Required only for local Discord notification tests/runs.
# In GitHub Actions, configure this as a repository secret instead.
DISCORD_WEBHOOK_URL=

# Optional LINE Messaging API notification settings.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=

# Required only if you intentionally publish from a local computer.
# GitHub Actions scheduled runs use github.token and do not need this.
GITHUB_REPORT_REPOSITORY=c20021013/taiwan-stock-reports
GITHUB_REPORT_TOKEN=

# Public report base URL.
REPORT_PUBLIC_BASE_URL=https://c20021013.github.io/taiwan-stock-reports

# Safety switches for local/manual runs.
# Leave empty unless you intentionally want local runs to update aliases or publish.
UPDATE_REPORT_ALIASES=
ALLOW_MANUAL_PUBLISH=
ALLOW_MANUAL_NOTIFY=
